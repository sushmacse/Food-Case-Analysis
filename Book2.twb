      <aliases enabled='yes' />
      <column caption='Gender1' datatype='string' name='[Calculation_2012398522204160]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Gender] = 1 THEN &quot;Female&quot;&#13;&#10;ELSE &quot;Male&quot;&#13;&#10;END' />
      </column>
      <column caption='Breakfast1' datatype='string' name='[Calculation_2012398522994689]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [breakfast] = 1 THEN &quot;Cerals&quot;&#13;&#10;ELSE &quot;Donut&quot;&#13;&#10;END' />
      </column>
      <column caption='Health' datatype='string' name='[Calculation_2012398525644804]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [fruit_day] &gt;= 4&#13;&#10;AND [fries] &lt;= 2&#13;&#10;AND [veggies_day] &gt;= 4&#13;&#10;AND INT([exercise]) &gt;= 1&#13;&#10;THEN &quot;Healthy&quot;&#13;&#10;ELSE &quot;Unhealthy&quot;&#13;&#10;END' />
      </column>
      <column caption='Weight1' datatype='integer' name='[Calculation_2012398528290821]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF ISNULL([weight]) THEN  160&#13;&#10;ELSE [weight] &#13;&#10;END' />
      </column>
      <column caption='Calculation1' datatype='integer' name='[Calculation_2012398553907206]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='CASE [Parameters].[Parameter 1]&#13;&#10;WHEN &quot;veggies_day&quot; THEN [veggies_day]&#13;&#10;WHEN &quot;fruit_day&quot; THEN [fruit_day]&#13;&#10;WHEN &quot;vitamins&quot; THEN [vitamins]&#13;&#10;END' />
      </column>
      <column caption='Calculation3' datatype='integer' name='[Calculation_2012398556102663]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Parameters].[Parameter 1] = &quot;thai_food&quot; THEN [thai_food]&#13;&#10;&#13;&#10;ELSEIF [Parameters].[Parameter 1] = &quot;italian_food&quot; THEN [italian_food]&#13;&#10;&#13;&#10;ELSEIF [Parameters].[Parameter 1] = &quot;greek_food&quot; THEN [greek_food]&#13;&#10;&#13;&#10;ELSEIF [Parameters].[Parameter 1] = &quot;indian_food&quot; THEN [indian_food]&#13;&#10;&#13;&#10;ELSE [persian_food]&#13;&#10;&#13;&#10;END' />
      </column>
      <column datatype='string' name='[Comfort Food Reasons (group) 1]' role='dimension' type='nominal'>
        <calculation class='categorical-bin' column='[comfort_food_reasons]' new-bin='true'>
          <bin default-name='false' value='&quot;Happiness&quot;'>
            <value>&quot;Bordem, happiness, sadness&quot;</value>
            <value>&quot;Boredom, happiness, distraught &quot;</value>
            <value>&quot;Happiness, boredom, social event&quot;</value>
            <value>&quot;happiness, hunger, sadness&quot;</value>
            <value>&quot;Happiness, sadness, celebration.&quot;</value>
            <value>&quot;happiness, satisfaction&quot;</value>
            <value>&quot;happiness, they are some of my favorite foods&quot;</value>
            <value>&quot;Sadness, happiness and boredom&quot;</value>
            <value>&quot;sadness, happiness and hunger&quot;</value>
          </bin>
        </calculation>
